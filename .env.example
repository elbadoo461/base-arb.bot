# ─────────────────────────────────────────────────────────────────────────────
# base-arb.bot — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── RPC Endpoints (required) ─────────────────────────────────────────────────

# HTTP JSON-RPC endpoint for Base Mainnet (used for polling + contract calls)
# Recommended providers: Alchemy, QuickNode, Chainstack, Infura
RPC_HTTP_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# WebSocket endpoint for Base Mainnet (optional but strongly recommended)
# Enables real-time block subscription instead of HTTP polling.
# Leave blank to fall back to HTTP-only mode.
RPC_WSS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Wallet (required for live execution) ─────────────────────────────────────

# Private key of the wallet that will sign and broadcast arbitrage transactions.
# Must hold enough ETH to cover gas fees.
# Omit or leave blank to run in scan-only / read-only mode.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Trade Parameters ─────────────────────────────────────────────────────────

# Size of each arbitrage trade in ETH (used as flash-loan amount)
TRADE_SIZE_ETH=1.0

# Minimum net profit in USD required before a strike is executed
MIN_NET_PROFIT_USD=2.0

# ── Contract Addresses ───────────────────────────────────────────────────────

# Address of your deployed arbitrage executor contract on Base Mainnet.
# Leave blank to run in scan-only mode (no on-chain execution).
EXECUTOR_CONTRACT=0xYOUR_EXECUTOR_CONTRACT_ADDRESS

# Aerodrome stable pool address for WETH/cbETH
# Default is pre-filled in bot.js; override here if the pool changes.
AERO_POOL_ADDRESS=0x44Cccbbd7A19A24b929Af4e3F09248B4B4E6f1f4

# ── Server ───────────────────────────────────────────────────────────────────

# Port for the health-check HTTP server (Railway sets this automatically)
PORT=8080
